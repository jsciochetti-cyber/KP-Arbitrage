# Copy to .env at repo root for docker-compose

DATABASE_URL=postgresql+asyncpg://arb:arb@localhost:5432/arb
REDIS_URL=redis://localhost:6379/0

KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2
POLY_GAMMA_URL=https://gamma-api.polymarket.com
POLY_CLOB_URL=https://clob.polymarket.com
POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Optional: Polymarket subgraph for whale indexing (Goldsky/hosted Graph)
POLY_SUBGRAPH_URL=

CORS_ORIGINS=http://localhost:3000

# Ingestion tuning
KALSHI_POLL_SECONDS=15
POLY_GAMMA_REFRESH_SECONDS=120
MAX_KALSHI_MARKETS=150
MAX_POLY_MARKETS=80
WHALE_MIN_USD=500
